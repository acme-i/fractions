<UserControl x:Class="fractions.ui.views.ClockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:fractions.ui.viewmodels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:ClockViewModel}">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- BPM input (disabled while clock is running) -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                   Text="BPM"
                   ToolTip="Beats Per Minute"
                   VerticalAlignment="Center"
                   Margin="0,0,6,0"/>

            <TextBox Grid.Column="1"
                 Text="{Binding BeatsPerMinute, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                 IsEnabled="{Binding IsNotRunning}"
                 VerticalAlignment="Center"
                 HorizontalContentAlignment="Left"
                 ToolTip="Beats Per Minute (editable only when stopped)"/>
        </Grid>

        <!-- Transport buttons: Reset | Start | Stop -->
        <UniformGrid Grid.Row="2" Rows="1" Columns="3">
            <Button Content="⏮ Reset"
                Command="{Binding ResetCommand}"
                ToolTip="Reset clock"
                Margin="0,0,2,0"/>
            <Button Content="▶ Start"
                Command="{Binding StartCommand}"
                ToolTip="Start clock"
                Margin="2,0,2,0"/>
            <Button Content="⏹ Stop"
                Command="{Binding StopCommand}"
                ToolTip="Stop clock"
                Margin="2,0,0,0"/>
        </UniformGrid>

        <!-- Status: elapsed time + running indicator -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                   Text="Time:"
                   VerticalAlignment="Center"
                   Margin="0,0,4,0"/>

            <TextBlock Grid.Column="1"
                   Text="{Binding Time, StringFormat=F2}"
                   VerticalAlignment="Center"/>

            <TextBlock Grid.Column="2"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text"        Value="⏸ Stopped"/>
                        <Setter Property="Foreground"  Value="Gray"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                <Setter Property="Text"       Value="▶ Running"/>
                                <Setter Property="Foreground" Value="Green"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

    </Grid>
</UserControl>
