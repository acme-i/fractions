<Window x:Class="fractions.ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:fractions.ui"
        xmlns:views="clr-namespace:fractions.ui.views"
        xmlns:vm="clr-namespace:fractions.ui.viewmodels"
        mc:Ignorable="d"
        FontSize="8"
        HorizontalAlignment="Stretch" VerticalAlignment="Top"
        Title="MainWindow" Height="450" Width="800"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"></ColumnDefinition>
            <ColumnDefinition Width="4"></ColumnDefinition>
            <ColumnDefinition Width="3*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <StackPanel Orientation="Vertical">
                <views:OutputDevicesView DataContext="{Binding OutputDevicesViewModel}"/>
                <views:ClockView DataContext="{Binding ClockViewModel}"/>
                
            </StackPanel>
        </Grid>
        <GridSplitter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="4" Background="Black" Grid.Column="1"></GridSplitter>
        <Grid  Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Vertical" Grid.Column="0">
                <views:NoteOnOffListView DataContext="{Binding NoteOnOffListViewModel}" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" />
            </StackPanel>
            <StackPanel Orientation="Vertical" Grid.Column="1">
                <views:FloatInterpolatorView DataContext="{Binding FloatInterpolatorViewModel}" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
